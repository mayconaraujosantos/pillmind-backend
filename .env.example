# Backend Environment Variables
PORT=8182

# Active environment: dev | prod
APP_ENV=dev

# --- Environment-specific database overrides (optional) ---
# If omitted, values from application-dev.properties / application-prod.properties are used.

# DEV
# DATABASE_URL_DEV=jdbc:postgresql://localhost:5432/pillmind_dev
# DATABASE_USER_DEV=postgres
# DATABASE_PASSWORD_DEV=postgres

# PROD (Railway example)
# DATABASE_URL_PROD=jdbc:postgresql://<user>:<password>@<host>:<port>/<database>?sslmode=require
# DATABASE_USER_PROD=postgres
# DATABASE_PASSWORD_PROD=<password>

# Legacy fallback (only if env-specific values are missing)
# DATABASE_URL=
# DATABASE_USER=
# DATABASE_PASSWORD=

GOOGLE_CLIENT_ID=1047433217870-r49q3eau6pq952hsrv8kc0o0f8anie7p.apps.googleusercontent.com

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRATION=86400

# Crypto Configuration
CRYPTO_ALGORITHM=AES/GCM/NoPadding
CRYPTO_KEY_SIZE=256

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:19000

# Redis Configuration (optional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO
